{
  "scale": {
    "1": {
      "label": "Trivial",
      "description": "CRUD simple, 1-5 campos planos, sin relaciones. ~0.5-1 día."
    },
    "2": {
      "label": "Estándar",
      "description": "Lista paginada + filtros + form con relaciones simples. ~1-2 días."
    },
    "3": {
      "label": "Complejo",
      "description": "Form con sub-tablas, props dinámicas, múltiples tabs. ~3-5 días."
    },
    "5": {
      "label": "Especializado",
      "description": "Visualizaciones (mapa, grafo, charts), estado complejo. ~1-2 semanas."
    },
    "8": {
      "label": "Subsistema",
      "description": "Módulo grande con builder propio, varios sub-flujos. ~2-4 semanas."
    }
  },
